## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is for .NET Core / .NET projects.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# VS Code
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# BlueJ files
*.ctxt

# Fruits
.DS_Store
Thumbs.db

# JetBrains
.idea/
*.iws
out/

# Rider
.rider/

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# NuGet Packages
*.nupkg
# The NuGet offline cache is still used by .NET Core SDK for project restore
# and should not be ignored.
# !**/Packages/nuget.sqlite
# !**/Packages/nuget.sqlite-journal

# Bak and temporary files
*.bak
*.tmp
*.temp

# Localized appsettings
appsettings.json
appsettings.Development.json
appsettings.*.json
!appsettings.json
!appsettings.Development.json
